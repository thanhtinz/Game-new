{
  "ConnectionStrings": {
    "MongoDB": "mongodb://worldfaith-mongo:27017",
    "Redis": "worldfaith-redis:6379"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "WorldFaith",
    "Audience": "WorldFaithPlayers",
    "AccessTokenMinutes": "60",
    "RefreshTokenDays": "30"
  },
  "Admin": {
    "Email": "${ADMIN_EMAIL}",
    "Password": "${ADMIN_PASSWORD}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Warning",
      "WorldFaith": "Information"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "AllowedHosts": "*"
}
